# Copia este archivo a "server/.env" y pega tu API key de Google AI Studio.
# server/.env está en .gitignore: NUNCA se sube al repositorio.
# La key vive SOLO aquí (en el servidor), nunca dentro del APK.

GEMINI_API_KEY=

# Opcional. Por defecto gemini-2.0-flash. Si te da error, prueba gemini-1.5-flash.
GEMINI_MODEL=gemini-2.0-flash

# Puerto del proxy.
PORT=3000
