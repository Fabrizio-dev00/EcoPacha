# EcoPacha - Proxy de IA (PLANTILLA)
# Copia este archivo a "server/.env" y pega tu key. server/.env esta en .gitignore.
# La key vive SOLO aqui (servidor), nunca dentro del APK.

# Proveedor: "groq" (gratis, sin tarjeta) o "gemini" (requiere facturacion)
PROVIDER=groq

# --- Groq ---  key gratis (sin tarjeta) en https://console.groq.com
GROQ_API_KEY=
# Modelo de vision de Groq. Si da error de modelo, mira los disponibles en
# https://console.groq.com/docs/models  (ej: meta-llama/llama-4-maverick-17b-128e-instruct)
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# --- Gemini (opcional, requiere facturacion en tu region) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

PORT=3000
