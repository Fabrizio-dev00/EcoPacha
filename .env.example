# EcoPacha - Variables de entorno (PLANTILLA)
# -------------------------------------------------------------------
# 1. Copia este archivo a ".env"  ->  cp .env.example .env
# 2. Completa los valores en tu entorno local.
# 3. ".env" esta en .gitignore: NUNCA se sube al repositorio ni al APK.
#
# IMPORTANTE: flutter_dotenv NO es una frontera de seguridad. El .env
# empaquetado se puede extraer del APK. Los SECRETOS REALES (API keys de IA)
# viven SOLO en el backend/Cloud Function, jamas dentro de Flutter.
# -------------------------------------------------------------------

# Alterna entre servicios simulados (demo) y reales. Para el MVP: true
USE_DEMO_SERVICES=true

# Endpoint del backend seguro que ejecuta la clasificacion con IA (Fase 8)
AI_BACKEND_URL=

# Endpoint del backend del chatbot EcoBot con IA (Fase 8)
CHATBOT_BACKEND_URL=
